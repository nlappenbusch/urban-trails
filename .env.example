# ── Mapbox ────────────────────────────────────────────────
# Token erstellen: https://account.mapbox.com/access-tokens/
# Public Token (pk.…) – wird im Browser verwendet
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── Gemini-TTS (Audio-Guides, Alternative zu ElevenLabs) ──
# Vertex AI Express Key (beginnt mit "AQ."):
# https://console.cloud.google.com/vertex-ai/studio
GEMINI_API_KEY=your_vertex_express_key_here
GEMINI_TTS_VOICE=Charon

# ── ElevenLabs (Audio-Guides, hat Vorrang wenn gesetzt) ───
# API-Key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice-ID einer warmen deutschen Stimme (z.B. aus der Voice Library)
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── OpenAI (optional: "Frag deinen Guide") ────────────────
OPENAI_API_KEY=sk-your_openai_key_here

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 1 = immer TTS-Stimme (einheitlich), 0 = fertige MP3s bevorzugen (laden sofort)
NEXT_PUBLIC_PREFER_TTS=1
